        <style>
    /* CSS بحرانی برای نمایش سریع layout اولیه */
    body { margin:0; font-family: Tahoma, sans-serif; visibility: visible !important; opacity: 1 !important;  }
    .header, .footer { visibility: visible;  animation: fadeIn 0.1s ease-out; }
    .main { min-height: 100vh;   animation: fadeIn 0.1s ease-out;}
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
        /* حذف تمام انیمیشن‌ها و تاخیرها */
        * {
            animation-duration: 0s !important;
            animation-delay: 0s !important;
            transition-duration: 0s !important;
            transition-delay: 0s !important;
        }
        
        [data-aos], [data-aos-delay] {
            opacity: 1 !important;
            transform: none !important;
        }
        
        .fade-up, .fade-down, .fade-left, .fade-right, .zoom-in, .zoom-out {
            opacity: 1 !important;
            transform: none !important;
        }
        
        /* نمایش فوری محتوا */
        body {
            visibility: visible !important;
            opacity: 1 !important;
        }
        
        /* استایل‌های پایه برای نمایش سریع */
        .hero, .about, .services, .skills, .resume, .portfolio, .team, .faq, .contact {
            visibility: visible;
        }
    </style>
    
    @await RenderSectionAsync("Heads", required: false)
</head>

<body class="index-page">
    <script>
            document.documentElement.style.visibility = 'visible';
