<!DOCTYPE html>
<html lang="fa" dir="rtl" id="html-root">

<head>
    <base href="/" />
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>@ViewData["Title"] - بیتا زر اندیش پارس </title>
    <meta name="description"
          content="شرکت بیتا زر اندیش پارس در حوزه سامانه‌های نرم‌افزاری تحت وب و اتوماسیون‌ها فعالیت می‌کند و با دانشگاه اصفهان در زمینه سامانه جامع پژوهشی و نرم‌افزارهای امنیتی همکاری دارد.">
    <meta name="keywords"
          content="سامانه‌های نرم‌افزاری, اتوماسیون, دانشگاه اصفهان, امنیت سایبری, پژوهش, فناوری اطلاعات, بیتا زر اندیش پارس">
    <meta name="robots" content="index, follow">
    <meta name="author" content="بیتا زر اندیش پارس">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="geo.placename" content="اصفهان, ایران">
    <meta name="geo.position" content="32.6523;51.6776">
    <meta name="geo.region" content="IR-ES">
    <meta property="og:title" content="بیتا زر اندیش پارس - نوآوری در سامانه‌های نرم‌افزاری">
    <meta property="og:description"
          content="شرکت بیتا زر اندیش پارس با تمرکز بر سامانه‌های نرم‌افزاری تحت وب و اتوماسیون‌ها، همکاری‌های موثری با دانشگاه اصفهان در سامانه جامع پژوهشی و امنیت سایبری دارد.">
    <meta property="og:image" content="~/assets/img/favicon.ico">
    <meta property="og:url" content="https://BitaZarAndishPars.ir">
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="بیتا زر اندیش پارس - نوآوری در سامانه‌های نرم‌افزاری">
    <meta name="twitter:description"
          content="شرکت بیتا زر اندیش پارس در حوزه سامانه‌های نرم‌افزاری تحت وب و اتوماسیون‌ها فعالیت می‌کند و با دانشگاه اصفهان در زمینه سامانه جامع پژوهشی و نرم‌افزارهای امنیتی همکاری دارد.">
    <meta name="twitter:image" content="~/assets/img/favicon.ico">

    <!-- Favicons -->
    <link href="assets/img/favicon.ico" rel="icon">
    <link href="assets/img/favicon.ico" rel="apple-touch-icon">

    <!-- DNS Prefetch & Preconnect for external resources -->
    <link rel="dns-prefetch" href="//www.google.com">
    <link rel="dns-prefetch" href="//www.gstatic.com">
    <link rel="preconnect" href="https://www.google.com" crossorigin>

    <!-- Preload critical assets -->
    <link rel="preload" href="assets/vendor/bootstrap/css/bootstrap.min.css" as="style">
    <link rel="preload" href="assets/css/main.css" as="style">

    <!-- Vendor CSS Files -->
    <link href="assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
    <link href="assets/vendor/aos/aos.css" rel="stylesheet">
    <link href="assets/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
    <link href="assets/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">

    <!-- Main CSS File -->
    <link href="assets/css/main.css" rel="stylesheet">

    <!-- Schema Markup for Local Business -->
    <script type="application/ld+json">
        {
        "@@context": "https://schema.org",
        "@@type": "LocalBusiness",
        "name": "بیتا زر اندیش پارس",
        "image": "https://BitaZarAndishPars.ir/assets/img/logo.png",
        "telephone": ["+983134543703", "+989132042385"],
        "email": "BitaZarAndishPars@gmail.com",
        "address": {
        "@@type": "PostalAddress",
        "streetAddress": "میدان آزادی، دانشگاه اصفهان، مرکز رشد و فناوری، طبقه همکف، واحد ۲",
        "addressLocality": "اصفهان",
        "addressRegion": "اصفهان",
        "addressCountry": "IR"
        },
        "url": "https://BitaZarAndishPars.ir",
        "description": "شرکت بیتا زر اندیش پارس در حوزه سامانه‌های نرم‌افزاری تحت وب و اتوماسیون‌ها فعالیت می‌کند و همکاری‌های موثری با دانشگاه اصفهان در زمینه سامانه جامع پژوهشی و اتوماسیون ساز و امنیت سایبری دارد.",
        "geo": {
        "@@type": "GeoCoordinates",
        "latitude": 32.6523,
        "longitude": 51.6776
        },
        "sameAs": [
        "https://twitter.com/BitaZarAndishPars",
        "https://facebook.com/BitaZarAndishPars",
        "https://linkedin.com/company/BitaZarAndishPars"
        ]
        }
    </script>
    @await RenderSectionAsync("Heads", required: false)
</head>

<body class="index-page">

    <header id="header" class="header d-flex align-items-center sticky-top">
        <div
            class="header-container container-fluid container-xl position-relative d-flex align-items-center justify-content-between">

            <a href="/" class="logo d-flex align-items-center me-auto me-xl-0">
                <img src="assets/img/favicon.ico" alt="logo">
            </a>

            <nav id="navmenu" class="navmenu">
                <ul>
                    <li><a href="#contact" data-i18n="nav.contact">تماس</a></li>
                    <li><a href="#services" data-i18n="nav.services">خدمات</a></li>
                    <li><a href="#portfolio" data-i18n="nav.products">محصولات</a></li>
                    <li><a href="#about" data-i18n="nav.about">درباره ما</a></li>
                    <li><a href="#hero" class="active" data-i18n="nav.home">خانه</a></li>
                </ul>
                <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
            </nav>

            <!-- Language Switcher -->
            <div class="lang-switcher" aria-label="Language switcher">
                <button class="lang-btn" data-lang="fa" onclick="SiteI18n.apply('fa')" title="فارسی">فا</button>
                <button class="lang-btn" data-lang="en" onclick="SiteI18n.apply('en')" title="English">EN</button>
                <button class="lang-btn" data-lang="ar" onclick="SiteI18n.apply('ar')" title="العربية">عر</button>
            </div>

        </div>
    </header>

    <main class="main">

        @RenderBody()

    </main>

    <footer id="footer" class="footer">

        <div class="container">
            <div class="copyright text-center ">
                <p>© <span></span> <strong class="px-1 sitename">بیتا زر اندیش پارس</strong> <span
                    data-i18n="footer.rights">تمامی حقوق محفوظ است</span></p>
                </div>
                <div class="credits">
                    <span data-i18n="footer.design">طراحی شده توسط</span> <a href="https://bizaptech.ir">شرکت بیتا زر اندیش
                    پارس</a>
                </div>
            </div>

        </footer>

        <!-- Scroll Top -->
        <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i
            class="bi bi-arrow-up-short"></i></a>

            <!-- Vendor JS Files (defer for faster page load) -->
            <script src="assets/vendor/bootstrap/js/bootstrap.bundle.min.js" defer></script>
            <script src="assets/vendor/aos/aos.js" defer></script>
            <script src="assets/vendor/waypoints/noframework.waypoints.js" defer></script>
            <script src="assets/vendor/glightbox/js/glightbox.min.js" defer></script>
            <script src="assets/vendor/imagesloaded/imagesloaded.pkgd.min.js" defer></script>
            <script src="assets/vendor/isotope-layout/isotope.pkgd.min.js" defer></script>
            <script src="assets/vendor/swiper/swiper-bundle.min.js" defer></script>

            <!-- i18n (must load before main.js) -->
            <script src="assets/js/i18n.js" defer></script>
            <!-- Main JS File -->
            <script src="assets/js/main.js" defer></script>
            @await RenderSectionAsync("Scripts", required: false)
        </body>

    </html>

















