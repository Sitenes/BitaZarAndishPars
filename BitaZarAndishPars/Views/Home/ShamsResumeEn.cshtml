<style>
    .resume-page {
        max-width: 960px;
        margin: 0 auto;
        direction: ltr;
        text-align: left;
    }

    .resume-header-card {
        background: linear-gradient(135deg, #0d6e6e 0%, #0a4a5c 100%);
        border-radius: 20px;
        padding: 56px 48px;
        color: #fff;
        position: relative;
        overflow: hidden;
    }

    .resume-header-card::before {
        content: '';
        position: absolute;
        top: -60px;
        right: -60px;
        width: 200px;
        height: 200px;
        background: rgba(255, 255, 255, .07);
        border-radius: 50%;
    }

    .resume-avatar {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        border: 5px solid rgba(255, 255, 255, .45);
        object-fit: cover;
        box-shadow: 0 8px 32px rgba(0, 0, 0, .25);
    }

    .resume-avatar-placeholder {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        border: 5px solid rgba(255, 255, 255, .45);
        background: rgba(255, 255, 255, .15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
    }

    .resume-name {
        font-size: 2.4rem;
        font-weight: 800;
        margin-bottom: 6px;
        letter-spacing: -.5px;
    }

    .resume-title-badge {
        background: rgba(255, 255, 255, .2);
        border-radius: 30px;
        padding: 7px 22px;
        font-size: 1.05rem;
        display: inline-block;
        margin-bottom: 16px;
        font-weight: 600;
    }

    .resume-lang-switch {
        position: absolute;
        top: 24px;
        right: 28px;
        background: rgba(255, 255, 255, .18);
        border: 1.5px solid rgba(255, 255, 255, .4);
        border-radius: 24px;
        padding: 6px 18px;
        color: #fff;
        font-size: .9rem;
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 7px;
        transition: background .2s;
    }

    .resume-lang-switch:hover {
        background: rgba(255, 255, 255, .3);
        color: #fff;
    }

    .contact-chip {
        background: rgba(255, 255, 255, .15);
        border-radius: 20px;
        padding: 4px 14px;
        font-size: .85rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin: 4px;
        text-decoration: none;
        color: #fff;
        transition: background .2s;
    }

    .contact-chip:hover {
        background: rgba(255, 255, 255, .3);
        color: #fff;
    }

    .resume-section {
        background: var(--surface-color);
        border-radius: 20px;
        padding: 40px 44px;
        margin-bottom: 28px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, .07);
    }

    .resume-section-title {
        font-size: 1.3rem;
        font-weight: 800;
        color: #0d6e6e;
        border-bottom: 2.5px solid #0d6e6e;
        padding-bottom: 12px;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .exp-card {
        border-left: 4px solid #0d6e6e;
        padding-left: 24px;
        margin-bottom: 36px;
        position: relative;
    }

    .exp-card::before {
        content: '';
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: #0d6e6e;
        position: absolute;
        left: -9px;
        top: 7px;
    }

    .exp-company {
        font-size: 1.18rem;
        font-weight: 800;
        color: var(--heading-color);
        margin-bottom: 3px;
    }

    .exp-role {
        color: #0d6e6e;
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .exp-period {
        font-size: .85rem;
        color: #888;
        background: var(--background-color);
        border-radius: 14px;
        padding: 3px 14px;
        display: inline-block;
        margin-bottom: 12px;
    }

    .exp-bullets {
        padding-left: 18px;
        margin-bottom: 12px;
    }

    .exp-bullets li {
        font-size: .93rem;
        line-height: 1.85;
        color: var(--default-color);
        margin-bottom: 3px;
    }

    .exp-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        margin-top: 10px;
    }

    .exp-tag {
        background: var(--background-color);
        border: 1px solid rgba(0, 0, 0, .08);
        border-radius: 16px;
        padding: 4px 14px;
        font-size: .82rem;
        color: var(--default-color);
        font-family: monospace;
    }

    .skill-group-title {
        font-size: .95rem;
        font-weight: 800;
        color: var(--heading-color);
        margin-bottom: 10px;
        margin-top: 20px;
    }

    .skill-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 9px;
    }

    .skill-tag {
        background: #0d6e6e;
        color: #fff;
        border-radius: 18px;
        padding: 6px 18px;
        font-size: .88rem;
        font-weight: 600;
    }

    .skill-tag-lib {
        background: var(--background-color);
        border: 1.5px solid #0d6e6e;
        color: #0d6e6e;
        border-radius: 18px;
        padding: 6px 18px;
        font-size: .88rem;
        font-weight: 600;
    }

    .edu-item {
        display: flex;
        align-items: flex-start;
        gap: 16px;
    }

    .edu-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: #0d6e6e;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.4rem;
        flex-shrink: 0;
    }

    .cert-card {
        background: var(--background-color);
        border-radius: 12px;
        padding: 16px 20px;
        margin-bottom: 14px;
        border-left: 3px solid #0d6e6e;
    }

    .cert-title {
        font-weight: 700;
        font-size: .98rem;
        color: var(--heading-color);
        margin-bottom: 3px;
    }

    .cert-meta {
        font-size: .82rem;
        color: #888;
    }

    .soft-skill-bar {
        margin-bottom: 14px;
    }

    .soft-skill-bar .ss-label {
        font-size: .9rem;
        font-weight: 600;
        color: var(--default-color);
        margin-bottom: 5px;
        display: flex;
        justify-content: space-between;
    }

    .lang-bar-wrap {
        margin-bottom: 12px;
    }

    .lang-bar-wrap .lang-label {
        font-size: .9rem;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .download-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: #0d6e6e;
        color: #fff;
        border-radius: 50px;
        padding: 14px 28px;
        font-size: 1rem;
        font-weight: 600;
        box-shadow: 0 6px 24px rgba(0, 0, 0, .2);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        z-index: 1000;
        transition: transform .2s, box-shadow .2s;
    }

    .download-btn:hover {
        color: #fff;
        transform: translateY(-3px);
        box-shadow: 0 10px 32px rgba(0, 0, 0, .25);
    }

    @@media print {
        .download-btn {
            display: none;
        }
    }
