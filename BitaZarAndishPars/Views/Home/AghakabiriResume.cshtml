<style>
    .resume-page {
        max-width: 960px;
        margin: 0 auto;
    }

    .resume-header-card {
        background: linear-gradient(135deg, var(--accent-color) 0%, #1a3a5c 100%);
        border-radius: 20px;
        padding: 56px 48px;
        color: #fff;
        position: relative;
        overflow: hidden;
    }

    .resume-header-card::before {
        content: '';
        position: absolute;
        top: -60px;
        left: -60px;
        width: 200px;
        height: 200px;
        background: rgba(255, 255, 255, .07);
        border-radius: 50%;
    }

    .resume-avatar {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        border: 5px solid rgba(255, 255, 255, .45);
        object-fit: cover;
        box-shadow: 0 8px 32px rgba(0, 0, 0, .25);
    }

    .resume-avatar-placeholder {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        border: 5px solid rgba(255, 255, 255, .45);
        background: rgba(255, 255, 255, .15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
    }

    .resume-name {
        font-size: 2.4rem;
        font-weight: 800;
        margin-bottom: 6px;
        letter-spacing: -.5px;
    }

    .resume-lang-switch {
        position: absolute;
        top: 24px;
        left: 28px;
        background: rgba(255, 255, 255, .18);
        border: 1.5px solid rgba(255, 255, 255, .4);
        border-radius: 24px;
        padding: 6px 18px;
        color: #fff;
        font-size: .9rem;
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 7px;
        transition: background .2s;
    }

    .resume-lang-switch:hover {
        background: rgba(255, 255, 255, .3);
        color: #fff;
    }

    .resume-title-badge {
        background: rgba(255, 255, 255, .2);
        border-radius: 30px;
        padding: 7px 22px;
        font-size: 1.05rem;
        display: inline-block;
        margin-bottom: 16px;
        font-weight: 600;
        letter-spacing: .3px;
    }

    .contact-chip {
        background: rgba(255, 255, 255, .15);
        border-radius: 20px;
        padding: 4px 14px;
        font-size: .85rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin: 4px;
        text-decoration: none;
        color: #fff;
        transition: background .2s;
    }

    .contact-chip:hover {
        background: rgba(255, 255, 255, .3);
        color: #fff;
    }

    .resume-section {
        background: var(--surface-color);
        border-radius: 20px;
        padding: 40px 44px;
        margin-bottom: 28px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, .07);
