        color: var(--heading-color);
        margin-bottom: 3px;
    }

    .exp-role {
        color: #0f6cbd;
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .exp-period {
        font-size: .85rem;
        color: #888;
        background: var(--background-color);
        border-radius: 14px;
        padding: 3px 14px;
        display: inline-block;
        margin-bottom: 12px;
    }

    .exp-bullets {
        padding-right: 18px;
        margin-bottom: 12px;
    }

    .exp-bullets li {
        font-size: .93rem;
        line-height: 1.85;
        color: var(--default-color);
        margin-bottom: 3px;
    }

    .exp-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        margin-top: 10px;
    }

    .exp-tag {
        background: var(--background-color);
        border: 1px solid rgba(0, 0, 0, .08);
        border-radius: 16px;
        padding: 4px 14px;
        font-size: .82rem;
        color: var(--default-color);
        font-family: monospace;
    }

    .skill-group-title {
        font-size: .95rem;
        font-weight: 800;
        color: var(--heading-color);
        margin-bottom: 10px;
        margin-top: 20px;
    }

    .skill-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 9px;
    }

    .skill-tag {
        background: #0f6cbd;
        color: #fff;
        border-radius: 18px;
        padding: 6px 18px;
        font-size: .88rem;
        font-weight: 600;
    }

    .skill-tag-lib {
        background: var(--background-color);
        border: 1.5px solid #0f6cbd;
        color: #0f6cbd;
        border-radius: 18px;
        padding: 6px 18px;
        font-size: .88rem;
        font-weight: 600;
    }

    .edu-item {
        display: flex;
        align-items: flex-start;
        gap: 16px;
    }

    .edu-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: #0f6cbd;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.4rem;
        flex-shrink: 0;
    }

    .lang-bar-wrap {
        margin-bottom: 12px;
    }

    .lang-bar-wrap .lang-label {
        font-size: .9rem;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .download-btn {
        position: fixed;
        bottom: 30px;
        left: 30px;
        background: #0f6cbd;
        color: #fff;
        border-radius: 50px;
        padding: 14px 28px;
        font-size: 1rem;
        font-weight: 600;
        box-shadow: 0 6px 24px rgba(0, 0, 0, .2);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        z-index: 1000;
        transition: transform .2s, box-shadow .2s;
    }

    .download-btn:hover {
        color: #fff;
        transform: translateY(-3px);
        box-shadow: 0 10px 32px rgba(0, 0, 0, .25);
    }

    @@media print {
        .download-btn {
            display: none;
        }
